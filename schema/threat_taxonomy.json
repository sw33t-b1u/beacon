  "business_trigger_map": {
    "m_and_a": {
      "additional_tags": [
        "espionage",
        "insider-threat"
      ],
      "rationale": "During M&A activity, state-sponsored and competitor intelligence collection against due-diligence data increases significantly."
    },
    "ot_connectivity": {
      "additional_tags": [
        "ot-targeting",
        "critical-infrastructure"
      ],
      "rationale": "IT/OT network convergence points serve as lateral movement pathways for supply-chain attackers targeting operational systems."
    },
    "cloud_migration": {
      "additional_tags": [
        "cloud-targeting"
      ],
      "rationale": "During migration windows, misconfigured cloud resources and hybrid-access credentials create elevated external exposure risk."
    },
    "ipo_or_listing": {
      "additional_tags": [
        "espionage",
        "fraud"
      ],
