# =============================================================================
# BEACON — Environment Variable Template
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and must never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP / Vertex AI  (required for LLM mode; not needed with --no-llm)
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
# Vertex AI region (default: us-central1)
# VERTEX_LOCATION=us-central1

# -----------------------------------------------------------------------------
# LLM model overrides  (optional — defaults shown below)
# -----------------------------------------------------------------------------
# BEACON_LLM_SIMPLE=gemini-2.5-flash-lite   # Markdown → JSON conversion
# BEACON_LLM_MEDIUM=gemini-2.5-flash        # PIR text augmentation
# BEACON_LLM_COMPLEX=gemini-2.5-pro         # Likelihood scoring assist

# -----------------------------------------------------------------------------
# GitHub / GHE Review Workflow  (required for cmd/submit_for_review.py)
# -----------------------------------------------------------------------------
GHE_TOKEN=your-github-personal-access-token
GHE_REPO=owner/repo
# For GitHub Enterprise Server, override the API base URL:
# GHE_API_BASE=https://your-ghe-host/api/v3

# -----------------------------------------------------------------------------
# SAGE Analysis API  (optional — enables --use-sage flag in cmd/generate_pir.py)
# -----------------------------------------------------------------------------
# SAGE_API_URL=http://localhost:8000
